{
    "compilerOptions": {
        "checkJs"          : true,
        "jsx"              : "react",
        "module"           : "esNext",
        "target"           : "esNext",
        "moduleResolution" : "bundler",
        "noImplicitThis"   : false,
        "noImplicitAny"    : false,
        "strictNullChecks" : false,
        "paths"            : {
            "*" : [
                "./src/*",
                "./node_modules/*"
            ]
        }
    },
    "exclude": [
        "node_modules",
        "**/node_modules/*"
    ]
}
